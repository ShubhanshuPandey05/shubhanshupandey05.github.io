{
    "experimentalServices": {
        "frontend": {
            "routePrefix": "/",
            "framework": "jekyll"
        },
        "backend": {
            "root": "backend",
            "routePrefix": "/_/backend"
        }
    },
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}